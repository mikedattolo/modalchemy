{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-schema/main/schema-2.0.json",
  "productName": "ModForge",
  "version": "0.1.0",
  "identifier": "com.modforge.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ModForge",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
